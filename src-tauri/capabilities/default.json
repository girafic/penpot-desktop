{
  "identifier": "default",
  "description": "Capabilities for Penpot Desktop",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:webview:default",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "core:app:default",
    "core:menu:default",
    "core:menu:allow-set-as-help-menu-for-nsapp",
    "opener:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ],
  "remote": {
    "urls": ["http://127.0.0.1:*/*"]
  }
}
